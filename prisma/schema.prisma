// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: We're using Supabase's built-in auth.users table for authentication
// This schema is for future application-specific models (orchards, inspections, etc.)
// that will reference the auth.users table via user_id

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  role      UserRole @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Reference to Supabase auth.users table
  @@map("profiles")
}

model Disease {
  id               String       @id @default(cuid())
  name             String       @unique
  type             DiseaseType
  severity         Int?         @default(0)
  spreadability    Int?         @default(0)
  shortDescription String?
  longDescription  String?
  controlMethod    String?
  imageLink        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("diseases")
}

enum UserRole {
  USER
  ADMIN
}

enum DiseaseType {
  DISEASE
  PEST
}
