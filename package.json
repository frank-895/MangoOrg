{
  "name": "mangoorg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "setup:storage": "node scripts/setup-storage.js",
    "test": "jest",
    "test:unit": "jest tests/unit --maxWorkers=4",
    "test:watch": "jest --watch tests/unit",
    "test:coverage": "jest --coverage",
    "test:ci": "jest tests/unit --ci --coverage --watchAll=false"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@supabase/supabase-js": "^2.38.4",
    "next": "14.0.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^6.0.3",
    "autoprefixer": "^10.0.1",
    "dotenv": "^16.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.3",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "postcss": "^8",
    "prisma": "^5.7.1",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.4.1",
    "tsx": "^4.6.2",
    "typescript": "^5"
  }
}
